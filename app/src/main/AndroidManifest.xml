<?xml version="1.0" encoding="utf-8"?>
<!-- Without this file, the app simply wouldn't be allowed to do anything. -->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <!-- WRITE_EXTERNAL_STORAGE is only needed on Android 9 and below.
         On Android 10+, MediaStore API is used instead which needs no permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage" />
    <uses-feature android:name="android.hardware.usb.host" />

    <!-- Tell Android 11+ which apps we need to interact with (package visibility). -->
    <queries>
        <!-- Needed to find gallery apps via CATEGORY_APP_GALLERY on Android 11+. -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.APP_GALLERY" />
        </intent>
        <!-- Google Photos / Gallery Go — don't declare CATEGORY_APP_GALLERY. -->
        <package android:name="com.google.android.apps.photos" />
        <package android:name="com.google.android.apps.photosgo" />
        <!-- Samsung Gallery — One UI 3+ uses a different package that doesn't
             declare CATEGORY_APP_GALLERY, so we must list it explicitly. -->
        <package android:name="com.samsung.android.app.gallery" />
        <package android:name="com.sec.android.gallery3d" />
        <!-- Other common manufacturer galleries that may skip the category. -->
        <package android:name="com.miui.gallery" />
        <package android:name="com.asus.gallery" />
        <package android:name="com.oneplus.gallery" />
        <package android:name="com.oppo.gallery3d" />
        <package android:name="com.vivo.gallery" />
    </queries>

    <application
        android:name="com.jiangdg.ausbc.base.BaseApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Digitapp">

        <activity
            android:name=".presentation.activity.MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize" />

        <activity
            android:name=".presentation.activity.SplashActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|smallestScreenSize"
            android:theme="@style/Theme.Digitapp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
